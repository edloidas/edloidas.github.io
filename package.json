{
  "name": "edloidas.github.io",
  "version": "5.0.0",
  "description": "Personal landing page with WebGL shader background",
  "author": "Mikita Taukachou <edloidas@gmail.com>",
  "license": "MIT",
  "type": "module",
  "homepage": "https://edloidas.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/edloidas/edloidas.github.io.git"
  },
  "keywords": [
    "personal",
    "landing-page",
    "webgl",
    "shader",
    "portfolio"
  ],
  "engines": {
    "node": ">=24.12.0",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "pnpm typecheck && pnpm lint",
    "fix": "pnpm lint:fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@types/node": "^25.0.3",
    "autoprefixer": "^10.4.23",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "modern-normalize": "^3.0.1",
    "postcss": "^8.5.6",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-glsl": "^1.5.5"
  },
  "browserslist": [
    "defaults and fully supports es6-module"
  ],
  "lint-staged": {
    "*.{ts,json,css}": "biome check --write"
  }
}
